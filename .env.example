# Auth (JWT) – required
JWT_SECRET=<generate with: openssl rand -hex 32>
JWT_REFRESH_SECRET=<generate with: openssl rand -hex 32>

# Database – required
DATABASE_URL="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority"

# App URL – set to your production URL for deployment
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# Optional: Auth0 (if you enable Auth0 later)
# AUTH0_SECRET=
# AUTH0_BASE_URL=
# AUTH0_ISSUER_BASE_URL=
# AUTH0_CLIENT_ID=

# Optional: Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional: Resend (email)
# RESEND_API_KEY=
# FROM_EMAIL=

# Optional: Cloudinary (avatars & file uploads)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
