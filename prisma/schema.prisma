

// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")

}

// ========== USER MANAGEMENT ==========
enum UserRole {
  CEO
  PROJECT_MANAGER
  TEAM_LEAD
  DEVELOPER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
  SUSPENDED
}

model User {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  email           String         @unique
  password        String         // Hashed password
  name            String
  role            UserRole
  status          UserStatus     @default(PENDING)
  avatar          String?        // URL to avatar image
  phone           String?
  department      String?
  jobTitle        String?
  
  // Timestamps
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  lastLoginAt     DateTime?
  emailVerified   Boolean        @default(false)
  
  // Relations
  projectsManaged Project[]      @relation("ProjectManager")
  projectsLed     Project[]      @relation("TeamLead")
  assignedTasks   Task[]         @relation("TaskAssignee")
  createdTasks    Task[]         @relation("TaskCreator")
  createdProjects Project[]      @relation("ProjectCreator")
  comments        Comment[]
  documents       Document[]
  notifications   Notification[]
  sessions        Session[]
  feedbacks       ClientFeedback[] @relation("FeedbackAuthor")
  activityLogs    ActivityLog[]    @relation("ActivityAuthor")
  
  // Single indexes - no duplicates
//   @@index([email])
  @@index([role])
  @@index([status])
}

model Session {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken   String   @unique
  userId         String   @db.ObjectId
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires        DateTime
  lastActive   DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
 
  // Single index - removed duplicate
//   @@index([sessionToken])
  @@index([userId])
}

// ========== PROJECT MANAGEMENT ==========
enum ProjectStatus {
  UPCOMING
  ACTIVE
  IN_DEVELOPMENT
  CLIENT_REVIEW
  COMPLETED
  ARCHIVED
  ON_HOLD
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

model Project {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  description     String?
  status          ProjectStatus  @default(UPCOMING)
  priority        ProjectPriority @default(MEDIUM)
  
  // Project Details
  startDate       DateTime?
  deadline        DateTime?
  completedAt     DateTime?
  estimatedHours  Float?
  actualHours     Float?
  progress        Float          @default(0) // 0-100
  budget          Float?         // Project budget
  cost            Float?         // Actual cost
  
  // Tracking
  riskLevel       RiskLevel      @default(LOW)
  isDelayed       Boolean        @default(false)
  delayReason     String?
  
  // Client Info
  clientName      String
  clientEmail     String
  clientCompany   String?
  clientPhone     String?
  
  // Timestamps
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  // Relations
  managerId       String         @db.ObjectId
  manager         User           @relation("ProjectManager", fields: [managerId], references: [id], onDelete: Restrict)
  
  teamLeadId      String?        @db.ObjectId
  teamLead        User?          @relation("TeamLead", fields: [teamLeadId], references: [id], onDelete: SetNull)
  
  createdById     String         @db.ObjectId
  createdBy       User           @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: Restrict)
  
  milestones      Milestone[]
  documents       Document[]
  feedbacks       ClientFeedback[]
  tasks           Task[]
  
  // Project metrics
  taskCount       Int            @default(0)
  completedTaskCount Int         @default(0)
  
  // Single indexes - no duplicates
  @@index([status])
  @@index([managerId])
  @@index([teamLeadId])
  @@index([clientEmail])
}

// ========== MILESTONE MANAGEMENT ==========
enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DELAYED
}

model Milestone {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  description     String?
  status          MilestoneStatus @default(PENDING)
  
  // Dates
  startDate       DateTime?
  deadline        DateTime?
  completedAt     DateTime?
  
  // Progress
  progress        Float          @default(0) // 0-100
  isDelayed       Boolean        @default(false)
  
  // Timestamps
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  // Relations
  projectId       String         @db.ObjectId
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  tasks           Task[]
  
  // Single indexes
  @@index([projectId])
  @@index([status])
}

// ========== TASK MANAGEMENT ==========
enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  REVIEW
  COMPLETED
  BLOCKED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  description     String?
  status          TaskStatus     @default(NOT_STARTED)
  priority        TaskPriority   @default(MEDIUM)
  
  // Dates
  startDate       DateTime?
  deadline        DateTime?
  completedAt     DateTime?
  
  // Time tracking
  estimatedHours  Float?
  actualHours     Float?
  
  // Relations
  projectId       String         @db.ObjectId
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  milestoneId     String?        @db.ObjectId
  milestone       Milestone?     @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  
  assigneeId      String?        @db.ObjectId
  assignee        User?          @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  
  createdById     String         @db.ObjectId
  createdBy       User           @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Restrict)
  
  // Additional
  attachments     Document[]
  comments        Comment[]
  
  // Task metrics
  isOverdue       Boolean        @default(false)
  reviewRequested Boolean        @default(false)
  reviewNotes     String?
  
  // Timestamps
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  // Single indexes - removed duplicates
  @@index([projectId])
  @@index([milestoneId])
  @@index([assigneeId])
  @@index([status])
  @@index([priority])
}

// ========== CLIENT FEEDBACK ==========
enum FeedbackStatus {
  PENDING
  REVIEWED
  APPROVED
  REJECTED
  REVISION_REQUESTED
}

model ClientFeedback {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  content         String
  stage           String         // "initial", "review", "revision", "approval"
  status          FeedbackStatus @default(PENDING)
  
  // Tracking
  revisionCount   Int            @default(0)
  isApproved      Boolean        @default(false)
  approvedAt      DateTime?
  
  // Feedback details
  rating          Int?           // 1-5 stars
  feedbackType    String?        // "design", "functionality", "bug", "enhancement"
  
  // Timestamps
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  // Relations
  projectId       String         @db.ObjectId
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  createdById     String         @db.ObjectId
  createdBy       User           @relation("FeedbackAuthor", fields: [createdById], references: [id], onDelete: Restrict)
  
  attachments     Document[]
  
  // Single indexes
  @@index([projectId])
  @@index([status])
}

// ========== DOCUMENT MANAGEMENT ==========
enum DocumentType {
  CLIENT_REQUIREMENT
  PROJECT_DOC
  TASK_ATTACHMENT
  FEEDBACK_ATTACHMENT
  CONTRACT
  INVOICE
  OTHER
}

model Document {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  fileName        String
  fileSize        Int
  fileType        String
  url             String
  type            DocumentType
  
  // Metadata
  description     String?
  version         String         @default("1.0.0")
  isPublic        Boolean        @default(false)
  
  // Timestamps
  uploadedAt      DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  // Relations - Fixed SetNull on required fields
  projectId       String?        @db.ObjectId
  project         Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  
  taskId          String?        @db.ObjectId
  task            Task?          @relation(fields: [taskId], references: [id], onDelete: SetNull)
  
  feedbackId      String?        @db.ObjectId
  feedback        ClientFeedback? @relation(fields: [feedbackId], references: [id], onDelete: SetNull)
  
  uploadedById    String         @db.ObjectId
  uploadedBy      User           @relation(fields: [uploadedById], references: [id], onDelete: Restrict)
  
  // Single indexes
  @@index([projectId])
  @@index([taskId])
  @@index([uploadedById])
  @@index([type])
}

// ========== COMMENT SYSTEM ==========
model Comment {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  content         String
  
  // Timestamps
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  // Relations
  taskId          String         @db.ObjectId
  task            Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  authorId        String         @db.ObjectId
  author          User           @relation(fields: [authorId], references: [id], onDelete: Restrict)
  
  // For nested comments - Fixed with proper referential actions
  parentId        String?        @db.ObjectId
  parent          Comment?       @relation("Replies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies         Comment[]      @relation("Replies")
  
  // Single indexes
  @@index([taskId])
  @@index([authorId])
  @@index([parentId])
}

// ========== NOTIFICATION SYSTEM ==========
enum NotificationType {
  TASK_ASSIGNED
  TASK_COMPLETED
  TASK_REVIEW
  MILESTONE_REACHED
  PROJECT_UPDATE
  FEEDBACK_RECEIVED
  DEADLINE_APPROACHING
  SYSTEM_ALERT
}

model Notification {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  type            NotificationType
  title           String
  message         String
  isRead          Boolean        @default(false)
  readAt          DateTime?
  
  // Action link
  link            String?        // URL to relevant page
  
  // Metadata
  metadata        Json?          // Additional data
  
  // Timestamps
  createdAt       DateTime       @default(now())
  
  // Relations
  userId          String         @db.ObjectId
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Single indexes
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// ========== INVITATIONS ==========
model Invitation {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  email       String
  token       String   @unique
  role        UserRole
  invitedById String   @db.ObjectId
  expiresAt  DateTime
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}

// ========== ACTIVITY LOGS ==========
model ActivityLog {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  action          String         // e.g., "CREATE_PROJECT", "UPDATE_TASK"
  entityType      String         // "project", "task", "user", etc.
  entityId        String
  details         Json?          // Changes made
  
  // Timestamps
  createdAt       DateTime       @default(now())
  
  // Relations - Fixed SetNull on required field
  userId          String?        @db.ObjectId  // Made optional to allow SetNull
  user            User?          @relation("ActivityAuthor", fields: [userId], references: [id], onDelete: SetNull)
  
  // Single indexes
  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}